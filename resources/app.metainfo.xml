<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.bgub.CosmicExtAppletVigil</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <project_group>COSMIC</project_group>
  <name>Vigil</name>
  <name xml:lang="uk">Зміна</name>
  <summary>Keep your screen awake — a vigil applet for the COSMIC desktop</summary>
  <summary xml:lang="uk">Не дає екрану заснути — віджет «Зміна» для COSMIC</summary>

  <developer id="com.github.bgub">
    <name>bgub</name>
  </developer>

  <url type="homepage">https://github.com/cosmic-utils/cosmic-ext-applet-vigil</url>
  <url type="bugtracker">https://github.com/cosmic-utils/cosmic-ext-applet-vigil/issues</url>

  <description>
    <p>A screen wake-lock applet for the COSMIC desktop environment. Prevent your
      display from dimming or sleeping with a single click from the panel.</p>
    <p xml:lang="uk">Віджет для середовища COSMIC, який запобігає автоматичному призупиненню пристрою,
      затемненню екрана або запуску заставки. Імітує активність користувача.</p>
  </description>

  <launchable type="desktop-id">com.github.bgub.CosmicExtAppletVigil.desktop</launchable>

  <icon type="stock">com.github.bgub.CosmicExtAppletVigil</icon>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/cosmic-utils/cosmic-ext-applet-vigil/main/screenshot.png</image>
      <caption>Vigil applet on the COSMIC panel</caption>
      <caption xml:lang="uk">Розміщений віджет на панелі.</caption>
    </screenshot>
  </screenshots>

  <provides>
    <binary>cosmic-ext-applet-vigil</binary>
  </provides>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>

  <categories>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>COSMIC</keyword>
    <keyword>vigil</keyword>
    <keyword>caffeine</keyword>
    <keyword>screen</keyword>
    <keyword>awake</keyword>
  </keywords>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.1.0" date="2026-03-07" />
  </releases>
</component>
