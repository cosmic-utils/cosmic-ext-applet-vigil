[Desktop Entry]
Name=Vigil
Comment=Keep your screen awake — a vigil applet for the COSMIC desktop
Type=Application
Icon=com.github.bgub.CosmicExtAppletVigil
Exec=cosmic-ext-applet-vigil
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC;vigil;caffeine;screen;awake;inhibit
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
